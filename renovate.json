{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchSourceUrls": [
        "https://github.com/open-telemetry/opentelemetry-rust",
        "https://github.com/tokio-rs/tracing-opentelemetry",
        "https://github.com/hyperium/tonic"
      ],
      "groupName": "opentelemetry-rust monorepo"
    },
    {
      "matchSourceUrls": [
        "https://github.com/maxcountryman/tower-sessions",
        "https://github.com/maxcountryman/tower-sessions-stores"
      ],
      "groupName": "tower-sessions monorepo"
    },
    {
      "matchSourceUrls": [
        "https://github.com/yewstack/yew"
      ],
      "groupName": "yew monorepo"
    }
  ],
  /*
   * Avoid churn
   */
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  /*
   * Make failures obvious instead of retrying forever
   */
  "rebaseWhen": "conflicted",
  "gitIgnoredAuthors": [
    "renovate[bot]@users.noreply.github.com"
  ]
}